// Prisma schema for the chat application
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  displayName  String
  about        String   @default("Hey there! I am using ChatApp.")
  avatarUrl    String?
  isOnline     Boolean  @default(false)
  lastSeen     DateTime @default(now())
  emailVerified Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sentMessages     Message[]      @relation("SentMessages")
  memberships      ChatMember[]
  refreshTokens    RefreshToken[]
  reactions        Reaction[]
  blockedUsers     BlockedUser[]  @relation("Blocker")
  blockedBy        BlockedUser[]  @relation("Blocked")
  callsMade        Call[]         @relation("CallsMade")
  callsReceived    Call[]         @relation("CallsReceived")
  starredMessages  StarredMessage[]
  hiddenMessages   HiddenMessage[]

  @@index([email])
  @@index([username])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// A Chat is either a 1-to-1 conversation or a group.
model Chat {
  id              String   @id @default(uuid())
  isGroup         Boolean  @default(false)
  name            String?  // group name (null for 1-to-1)
  description     String?
  iconUrl         String?
  pinnedMessageId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members       ChatMember[]
  messages      Message[]
  pinnedMessage Message?     @relation("PinnedMessage", fields: [pinnedMessageId], references: [id], onDelete: SetNull)

  @@index([isGroup])
}

model ChatMember {
  id       String   @id @default(uuid())
  chatId   String
  userId   String
  isAdmin  Boolean  @default(false)
  joinedAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId])
}

model Message {
  id              String        @id @default(uuid())
  chatId          String
  senderId        String
  content         String?
  type            MessageType   @default(TEXT)
  fileUrl         String?
  fileName        String?
  fileSize        Int?
  replyToId       String?
  forwardedFromId String?
  isEdited        Boolean       @default(false)
  isDeleted       Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  chat            Chat             @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender          User             @relation("SentMessages", fields: [senderId], references: [id])
  replyTo         Message?         @relation("Replies", fields: [replyToId], references: [id])
  replies         Message[]        @relation("Replies")
  forwardedFrom   Message?         @relation("Forwards", fields: [forwardedFromId], references: [id])
  forwardedCopies Message[]        @relation("Forwards")
  reactions       Reaction[]
  receipts        MessageReceipt[]
  starredBy       StarredMessage[]
  hiddenFor       HiddenMessage[]
  pinnedInChats   Chat[]           @relation("PinnedMessage")

  @@index([chatId, createdAt])
  @@index([senderId])
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  VOICE
  FILE
}

model MessageReceipt {
  id        String        @id @default(uuid())
  messageId String
  userId    String
  status    ReceiptStatus @default(DELIVERED)
  updatedAt DateTime      @updatedAt

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

enum ReceiptStatus {
  DELIVERED
  READ
}

model Reaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

// Per-user "starred" flag — independent of the message itself.
model StarredMessage {
  id        String   @id @default(uuid())
  userId    String
  messageId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@index([messageId])
}

// Per-user "deleted for me" — hides a message from this user's view only,
// independent of the message's real isDeleted ("deleted for everyone") state.
model HiddenMessage {
  id        String   @id @default(uuid())
  userId    String
  messageId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@index([messageId])
}

model BlockedUser {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

// A logged call attempt between two users (1-to-1 only). chatId is a plain
// scalar, not a relation — call history is a log/audit trail and should
// survive chat deletion.
model Call {
  id              String     @id @default(uuid())
  callerId        String
  calleeId        String
  chatId          String?
  callType        CallType
  status          CallStatus @default(MISSED)
  startedAt       DateTime?
  endedAt         DateTime?
  durationSeconds Int?
  createdAt       DateTime   @default(now())

  caller User @relation("CallsMade", fields: [callerId], references: [id], onDelete: Cascade)
  callee User @relation("CallsReceived", fields: [calleeId], references: [id], onDelete: Cascade)

  @@index([callerId])
  @@index([calleeId])
  @@index([createdAt])
}

enum CallType {
  VOICE
  VIDEO
}

enum CallStatus {
  MISSED
  ANSWERED
  REJECTED
  CANCELLED
}
