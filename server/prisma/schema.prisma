// Prisma schema for the chat application
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  displayName  String
  about        String   @default("Hey there! I am using ChatApp.")
  avatarUrl    String?
  isOnline     Boolean  @default(false)
  lastSeen     DateTime @default(now())
  emailVerified Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sentMessages     Message[]      @relation("SentMessages")
  memberships      ChatMember[]
  refreshTokens    RefreshToken[]
  reactions        Reaction[]
  blockedUsers     BlockedUser[]  @relation("Blocker")
  blockedBy        BlockedUser[]  @relation("Blocked")

  @@index([email])
  @@index([username])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// A Chat is either a 1-to-1 conversation or a group.
model Chat {
  id          String   @id @default(uuid())
  isGroup     Boolean  @default(false)
  name        String?  // group name (null for 1-to-1)
  description String?
  iconUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  ChatMember[]
  messages Message[]

  @@index([isGroup])
}

model ChatMember {
  id       String   @id @default(uuid())
  chatId   String
  userId   String
  isAdmin  Boolean  @default(false)
  joinedAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId])
}

model Message {
  id          String        @id @default(uuid())
  chatId      String
  senderId    String
  content     String?
  type        MessageType   @default(TEXT)
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  replyToId   String?
  isEdited    Boolean       @default(false)
  isDeleted   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  chat     Chat       @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender   User       @relation("SentMessages", fields: [senderId], references: [id])
  replyTo  Message?   @relation("Replies", fields: [replyToId], references: [id])
  replies  Message[]  @relation("Replies")
  reactions Reaction[]
  receipts MessageReceipt[]

  @@index([chatId, createdAt])
  @@index([senderId])
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  VOICE
  FILE
}

model MessageReceipt {
  id        String        @id @default(uuid())
  messageId String
  userId    String
  status    ReceiptStatus @default(DELIVERED)
  updatedAt DateTime      @updatedAt

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

enum ReceiptStatus {
  DELIVERED
  READ
}

model Reaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model BlockedUser {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}
